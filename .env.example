# Never commit real API keys.
# Copy to .env in the project root or server/ folder. Restart the server after changes.
GROQ_API_KEY=
PORT=5050

# Production (Vercel): set GROQ_API_KEY in the Vercel dashboard (Production + Preview).
# Local dev: leave VITE_API_URL unset; Vite proxies /api to the Express server on PORT.
# Optional: point the built client at an external API host.
# VITE_API_URL=

# ── Firebase (optional) ──────────────────────────────────────────────────────
# Firebase is optional. The app works fully without these values.
# Set them to enable Google sign-in and Firestore cloud save for investment briefs.
# Get values from: https://console.firebase.google.com → Project settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
